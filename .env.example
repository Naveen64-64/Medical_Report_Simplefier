# Flask configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=dev_secret_key_change_me_in_production

# Database configuration
DATABASE_PATH=database.db

# LLM & Translator configurations
# Get your OpenAI/OpenRouter API key from https://platform.openai.com/ or https://openrouter.ai/
OPENAI_API_KEY=your_openai_or_openrouter_api_key_here
OPENAI_MODEL=google/gemini-2.5-flash

# OCR settings (Tesseract Executable Path - modify if needed)
# On Windows, commonly: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
